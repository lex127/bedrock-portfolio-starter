DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_HOST=db
DB_PREFIX=wp_

WP_ENV=development
WP_HOME=http://localhost:8880
WP_SITEURL=${WP_HOME}/wp

# Mail
MAIL_FROM=
MAIL_FROM_NAME=
MAIL_NOTIFICATION_TO=
SMTP_HOST=
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_AUTOTLS=false
SMTP_USER=
SMTP_PASS=

# Generate your own salts at https://roots.io/salts.html
AUTH_KEY='generateme'
SECURE_AUTH_KEY='generateme'
LOGGED_IN_KEY='generateme'
NONCE_KEY='generateme'
AUTH_SALT='generateme'
SECURE_AUTH_SALT='generateme'
LOGGED_IN_SALT='generateme'
NONCE_SALT='generateme'
